{
  "rewrites": [
    {
      "source": "/api/wc-live/:path*",
      "destination": "/api/rapid?service=wc-live&upstream=:path*"
    },
    {
      "source": "/api/wc2026/:path*",
      "destination": "/api/rapid?service=wc2026&upstream=:path*"
    },
    {
      "source": "/api/footballdata/:path*",
      "destination": "/api/rapid?service=footballdata&upstream=:path*"
    },
    {
      "source": "/api/sportapi/:path*",
      "destination": "/api/rapid?service=sportapi&upstream=:path*"
    },
    {
      "source": "/api/sofascore6/:path*",
      "destination": "/api/rapid?service=sofascore6&upstream=:path*"
    },
    {
      "source": "/api/sofascore-rapid/:path*",
      "destination": "/api/rapid?service=sofascore-rapid&upstream=:path*"
    },
    {
      "source": "/api/weather/:path*",
      "destination": "/api/rapid?service=weather&upstream=:path*"
    },
    {
      "source": "/api/odds/:path*",
      "destination": "/api/rapid?service=odds&upstream=:path*"
    },
    {
      "source": "/api/football-prediction/:path*",
      "destination": "/api/rapid?service=football-prediction&upstream=:path*"
    },
    {
      "source": "/api/world-cup-history/:path*",
      "destination": "/api/rapid?service=world-cup-history&upstream=:path*"
    },
    {
      "source": "/api/sport-highlights/:path*",
      "destination": "/api/rapid?service=sport-highlights&upstream=:path*"
    },
    {
      "source": "/api/sports-live-scores/:path*",
      "destination": "/api/rapid?service=sports-live-scores&upstream=:path*"
    },
    {
      "source": "/api/all-sport-live-stream/:path*",
      "destination": "/api/rapid?service=all-sport-live-stream&upstream=:path*"
    },
    {
      "source": "/api/free-daily-xtream-iptv/:path*",
      "destination": "/api/rapid?service=free-daily-xtream-iptv&upstream=:path*"
    },
    {
      "source": "/api/cloud-api-hub-iptv/:path*",
      "destination": "/api/rapid?service=cloud-api-hub-iptv&upstream=:path*"
    },
    {
      "source": "/api/tvview/:path*",
      "destination": "/api/rapid?service=tvview&upstream=:path*"
    },
    {
      "source": "/api/zafronix/:path*",
      "destination": "/api/rapid?service=zafronix&upstream=:path*"
    },
    {
      "source": "/api/espn-web/:path*",
      "destination": "/api/proxy?upstream=:path*"
    },
    {
      "source": "/espn/:path*",
      "destination": "https://site.api.espn.com/:path*"
    },
    {
      "source": "/espn-web/:path*",
      "destination": "https://site.web.api.espn.com/:path*"
    },
    {
      "source": "/poly/:path*",
      "destination": "https://gamma-api.polymarket.com/:path*"
    },
    {
      "source": "/fifa-api/:path*",
      "destination": "https://www.fifa.com/:path*"
    },
    {
      "source": "/fifa/:path*",
      "destination": "https://inside.fifa.com/:path*"
    },
    {
      "source": "/api/sofascore6/:path*",
      "destination": "/api/sofascore6/:path*"
    },
    {
      "source": "/api/sofascore/:path*",
      "destination": "/api/sofascore?path=:path*"
    },
    {
      "source": "/api/clubelo/:path*",
      "destination": "/api/clubelo"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; connect-src 'self' https://site.api.espn.com https://site.web.api.espn.com https://gamma-api.polymarket.com https://api.fifa.com https://www.fifa.com https://api.sofascore.com https://sofascore6.p.rapidapi.com http://api.clubelo.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
        }
      ]
    }
  ]
}
